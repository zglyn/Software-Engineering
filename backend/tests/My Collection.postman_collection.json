      "name": "UserManagement",
      "item": [
        {
          "name": "Users test",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Valid status (200 or 400 or 404)\", () => {\r",
                  "    pm.expect([200, 400, 404]).to.include(pm.response.code);\r",
                  "});\r",
                  "\r",
                  "if (pm.response.code === 200) {\r",
                  "    pm.test(\"User data returned successfully\", () => {\r",
                  "        const data = pm.response.json();\r",
                  "        pm.expect(data).to.be.an(\"array\"); \r",
                  "    });\r",
                  "}\r",
                  "\r",
                  "if (pm.response.code !== 200) {\r",
                  "    pm.test(\"Error message exists\", () => {\r",
                  "        pm.expect(pm.response.json()).to.have.property(\"error\");\r",
                  "    });\r",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
