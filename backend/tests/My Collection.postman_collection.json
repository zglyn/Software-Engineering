                  "        \r",
                  "        const firstGame = data.games[0];\r",
                  "        const dateProperty = firstGame.gameDate || firstGame.GAME_DATE || firstGame.date;\r",
                  "        \r",
                  "        pm.expect(dateProperty).to.not.be.undefined;\r",
                  "        console.log(\"Game ID Found:\", firstGame.gameId);\r",
